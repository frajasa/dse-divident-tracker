# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/dse_dividends

# DSE data source
DSE_API_BASE_URL=https://data.dse.co.tz

# App secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# Africa's Talking SMS (optional)
SMS_API_KEY=your-africas-talking-api-key
SMS_USERNAME=your-africas-talking-username

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=your-whatsapp-business-api-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-meta-app-secret

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000

# API base URL for WhatsApp bot
API_BASE_URL=http://localhost:8000
